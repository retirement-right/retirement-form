  </div>`;
}

async function submitForm() {
  const data = collectData();
  const filled = Object.values(data).filter(v => Array.isArray(v) ? v.length : v !== '').length;
  if (filled === 0) {
    const msg = document.getElementById('submit-msg');
    msg.className = 'warning';
    msg.textContent = 'Your form appears to be blank. Please fill in at least your name and one other field before submitting.';
    return;
  }

  const btn = document.getElementById('submit-btn');
  btn.disabled = true;
  btn.textContent = 'Sending…';

  try {
    const payload = {
      access_key: '07e7ab7a-15c7-49af-aea6-a97fbc690fa6',
      subject: `Pre-Appointment Form — ${data.p_name || 'New Client'}`,
      from_name: 'Retirement Right Intake Form',
      email: data.p_email || undefined,
      message: buildEmailHTML(data)
    };

    const res = await fetch('https://api.web3forms.com/submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify(payload)
    });
    const result = await res.json();
    if (res.ok && result.success) {
      document.getElementById('success-modal').classList.add('open');
      try { localStorage.removeItem('rr_preappt'); } catch(e) {}
    } else {
      throw new Error('Server error');
    }
  } catch(e) {
    const msg = document.getElementById('submit-msg');
    msg.className = 'error';
    msg.textContent = 'Something went wrong — please call 602-598-2992 or email michael@retirement-right.com directly.';
  }

  btn.disabled = false;
  btn.textContent = '📤 Submit to Advisor';
}
</script>
