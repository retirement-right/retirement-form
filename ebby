<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pre-Appointment Information — Retirement Right</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #1a2744; --gold: #c9a84c; --light-gold: #f5edda;
    --bg: #f7f8fa; --white: #fff; --border: #dde2ec;
    --text: #222; --muted: #6b7280; --green: #16a34a;
    --red: #dc2626; --radius: 8px;
  }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); font-size: 15px; line-height: 1.5; }

  header { background: var(--navy); color: white; padding: 20px 16px 16px; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.25); }
  .header-inner { max-width: 820px; margin: 0 auto; }
  header h1 { font-size: 1.2rem; font-weight: 700; letter-spacing: .02em; color: var(--gold); }
  header p { font-size: .8rem; opacity: .7; margin-top: 2px; }
  #autosave-indicator { font-size: .75rem; opacity: .65; margin-top: 8px; min-height: 16px; color: #a5f3b4; }

  main { max-width: 820px; margin: 0 auto; padding: 28px 16px 60px; }

  .banner { background: var(--light-gold); border: 1px solid var(--gold); border-radius: 10px; padding: 20px 24px; margin-bottom: 24px; text-align: center; }
  .banner h2 { font-size: 1.05rem; font-weight: 700; color: var(--navy); margin-bottom: 8px; }
  .banner p { font-size: .88rem; color: #5a4a1a; line-height: 1.6; margin-bottom: 6px; }
  .banner small { font-size: .78rem; color: var(--muted); }

  .section { background: var(--white); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 20px; overflow: hidden; }
  .section-header { background: var(--navy); color: white; padding: 14px 20px; display: flex; align-items: center; gap: 12px; }
  .section-num { background: var(--gold); color: #1a1a1a; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: .85rem; flex-shrink: 0; }
  .section-header h2 { font-size: 1rem; font-weight: 600; }
  .section-body { padding: 20px; }

  .info-table { width: 100%; border-collapse: collapse; }
  .info-table th { font-size: .75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; padding: 0 8px 8px 8px; text-align: left; }
  .info-table th:first-child { width: 90px; }
  .info-table td { padding: 6px 8px; vertical-align: middle; }
  .info-table td:first-child { font-size: .88rem; font-weight: 600; color: var(--navy); white-space: nowrap; }

  .asset-table { width: 100%; border-collapse: collapse; }
  .asset-table th { font-size: .75rem; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; padding: 8px 10px; text-align: left; border-bottom: 2px solid var(--border); }
  .asset-table th:not(:first-child) { text-align: center; color: var(--navy); }
  .asset-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); font-size: .88rem; vertical-align: middle; }
  .asset-table td:first-child { font-weight: 500; color: var(--text); }
  .asset-table td.sub { font-size: .8rem; color: var(--muted); padding-left: 22px; background: #fafbfc; }
  .asset-table td:not(:first-child) { text-align: center; }
  .asset-table tr:last-child td { border-bottom: none; }

  .bottom-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
  @media(max-width:600px) { .bottom-grid { grid-template-columns: 1fr; } }

  .field { display: flex; flex-direction: column; gap: 4px; }
  label.field-label { font-size: .78rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .04em; }

  input[type=text], input[type=date], input[type=email], input[type=tel], input[type=number] {
    width: 100%; padding: 7px 10px; border: 1px solid var(--border); border-radius: 6px;
    font-size: .9rem; font-family: inherit; color: var(--text); background: white; -webkit-appearance: none;
  }
  input:focus { outline: none; border-color: var(--gold); box-shadow: 0 0 0 3px rgba(201,168,76,.15); }

  /* Dollar inputs as text with $ prefix */
  .dollar-wrap { position: relative; }
  .dollar-wrap::before { content: '$'; position: absolute; left: 8px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: .85rem; pointer-events: none; z-index:1; }
  .dollar-wrap input { padding-left: 20px; }

  .check-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .check-list li label { display: flex; align-items: center; gap: 10px; font-size: .9rem; cursor: pointer; }
  .check-list input[type=checkbox] { width: 18px; height: 18px; accent-color: var(--gold); cursor: pointer; flex-shrink: 0; }

  .submit-area { background: var(--white); border: 1px solid var(--border); border-radius: 12px; padding: 24px 20px; text-align: center; }
  .btn-submit { display: inline-flex; align-items: center; gap: 8px; padding: 12px 32px; background: var(--green); color: white; border: none; border-radius: var(--radius); font-size: 1rem; font-weight: 700; cursor: pointer; transition: background .15s; }
  .btn-submit:hover { background: #15803d; }
  .btn-submit:disabled { background: #9ca3af; cursor: not-allowed; }
  #submit-msg { margin-top: 14px; font-size: .9rem; min-height: 20px; }
  #submit-msg.success { color: var(--green); font-weight: 600; }
  #submit-msg.error { color: var(--red); }
  #submit-msg.warning { color: #b45309; }

  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: white; border-radius: 12px; padding: 28px 24px; max-width: 400px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,.3); text-align: center; }
  .modal h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: 10px; }
  .modal p { font-size: .88rem; color: var(--muted); margin-bottom: 20px; line-height: 1.6; }
  .btn-primary { display: inline-flex; align-items: center; padding: 10px 24px; background: var(--navy); color: white; border: none; border-radius: var(--radius); font-size: .9rem; font-weight: 600; cursor: pointer; }
  .btn-primary:hover { background: #253563; }

  footer { text-align: center; font-size: .75rem; color: var(--muted); padding: 20px; border-top: 1px solid var(--border); margin-top: 8px; }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <h1>Retirement Right</h1>
    <p>Pre-Appointment Information — Confidential</p>
    <div id="autosave-indicator">Auto-save is on — your data is saved in this browser</div>
  </div>
</header>

<main>

