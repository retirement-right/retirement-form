</main>

<footer>CONFIDENTIAL — For Planning Purposes Only. This form does not constitute investment, legal, or tax advice. | © 2026 Retirement Right</footer>

<div class="modal-overlay" id="success-modal">
  <div class="modal">
    <div style="font-size:2.5rem;margin-bottom:12px">✅</div>
    <h3>Form Submitted!</h3>
    <p>Your information has been received. Your advisor will be in touch shortly to confirm your appointment.</p>
    <button class="btn-primary" onclick="document.getElementById('success-modal').classList.remove('open')">Done</button>
  </div>
</div>

<script>
// ── DOLLAR FORMATTING ─────────────────────────────────────────
function formatDollar(val) {
  const num = parseFloat(val.replace(/[^0-9.]/g, ''));
  if (isNaN(num)) return '';
  return num.toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
}
function rawDollar(val) {
  return val.replace(/[^0-9.]/g, '');
}

document.querySelectorAll('.dollar-input').forEach(input => {
  // Allow only numbers and decimals while typing
  input.addEventListener('input', function() {
    const pos = this.selectionStart;
    const raw = rawDollar(this.value);
    this.value = raw; // keep raw while typing
  });
  // Format on blur
  input.addEventListener('blur', function() {
    if (this.value) this.value = formatDollar(this.value);
  });
  // Strip commas on focus so user can edit cleanly
  input.addEventListener('focus', function() {
    this.value = rawDollar(this.value);
  });
});

// ── PHONE FORMATTING ─────────────────────────────────────────
function formatPhone(val) {
  const digits = val.replace(/\D/g, '').slice(0, 10);
  if (digits.length <= 3) return digits;
  if (digits.length <= 6) return `${digits.slice(0,3)}-${digits.slice(3)}`;
  return `${digits.slice(0,3)}-${digits.slice(3,6)}-${digits.slice(6)}`;
}

document.getElementById('p_phone').addEventListener('input', function() {
  const pos = this.selectionStart;
  this.value = formatPhone(this.value);
});


function calcAge(dob) {
  if (!dob) return '';
  const today = new Date();
  const birth = new Date(dob);
  let age = today.getFullYear() - birth.getFullYear();
  const m = today.getMonth() - birth.getMonth();
  if (m < 0 || (m === 0 && today.getDate() < birth.getDate())) age--;
  return age >= 0 && age < 120 ? age : '';
}
function calcDOB(age) {
  if (!age || age < 1 || age > 110) return '';
  const year = new Date().getFullYear() - parseInt(age);
  return `${year}-01-01`;
}

document.getElementById('p_dob').addEventListener('change', function() {
  const age = calcAge(this.value);
  if (age !== '') document.getElementById('p_age').value = age;
});
document.getElementById('p_age').addEventListener('change', function() {
  if (!document.getElementById('p_dob').value && this.value)
    document.getElementById('p_dob').value = calcDOB(this.value);
});
document.getElementById('s_dob').addEventListener('change', function() {
  const age = calcAge(this.value);
  if (age !== '') document.getElementById('s_age').value = age;
});
document.getElementById('s_age').addEventListener('change', function() {
  if (!document.getElementById('s_dob').value && this.value)
    document.getElementById('s_dob').value = calcDOB(this.value);
});

// ── DATA COLLECTION ───────────────────────────────────────────
function collectData() {
  const data = {};
  document.querySelectorAll('input[id]').forEach(el => {
    if (el.type === 'file') return;
    if (el.type === 'checkbox' && el.name !== 'estate') {
      data[el.id] = el.checked.toString();
    } else if (el.type !== 'checkbox') {
      // Store raw number for dollar fields
      data[el.id] = el.classList.contains('dollar-input') ? rawDollar(el.value) : el.value;
    }
  });
  const estate = [];
  document.querySelectorAll('input[name=estate]:checked').forEach(el => estate.push(el.value));
  data.estate = estate;
  return data;
}

function populateData(data) {
  document.querySelectorAll('input[id]').forEach(el => {
    if (el.type === 'file') return;
    if (el.type === 'checkbox' && el.name !== 'estate' && data[el.id] !== undefined) {
      el.checked = data[el.id] === 'true';
    } else if (el.type !== 'checkbox' && data[el.id] !== undefined) {
      el.value = data[el.id];
      // Re-format dollar fields on load
      if (el.classList.contains('dollar-input') && el.value)
        el.value = formatDollar(el.value);
    }
  });
  document.querySelectorAll('input[name=estate]').forEach(el => {
    el.checked = (data.estate || []).includes(el.value);
  });
}

// ── AUTO-SAVE ─────────────────────────────────────────────────
let saveTimer = null;
function autoSave() {
  try {
    localStorage.setItem('rr_preappt', JSON.stringify(collectData()));
    const t = new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
    document.getElementById('autosave-indicator').textContent = `✓ Auto-saved at ${t}`;
  } catch(e) {}
}
document.addEventListener('input', () => { clearTimeout(saveTimer); saveTimer = setTimeout(autoSave, 1000); });
document.addEventListener('change', () => { clearTimeout(saveTimer); saveTimer = setTimeout(autoSave, 1000); });
window.addEventListener('DOMContentLoaded', () => {
  try {
    const raw = localStorage.getItem('rr_preappt');
    if (raw) {
      const data = JSON.parse(raw);
      populateData(data);
      const filled = Object.values(data).filter(v => Array.isArray(v) ? v.length : v !== '').length;
      if (filled > 0) document.getElementById('autosave-indicator').textContent = `↩ Restored ${filled} saved fields from your last session`;
    }
  } catch(e) {}
});

// ── SUBMIT ─────────────────────────────────────────────────
function fmt(val) { return val ? `$${Number(rawDollar(val)).toLocaleString('en-US')}` : '—'; }

function buildEmailHTML(data) {
  const row = (label, val) => `
    <tr>
      <td style="padding:6px 10px;font-size:13px;color:#222;border-bottom:1px solid #e5e7eb;">${label}</td>
      <td style="padding:6px 10px;font-size:13px;color:#1a2744;font-weight:600;border-bottom:1px solid #e5e7eb;text-align:right;">${val}</td>
    </tr>`;
  const sectionHdr = (num, title) => `
    <tr>
      <td colspan="2" style="background:#1a2744;color:#fff;font-size:13px;font-weight:700;padding:10px 14px;border-radius:6px 6px 0 0;">
        <span style="background:#c9a84c;color:#1a1a1a;border-radius:50%;display:inline-block;width:20px;height:20px;text-align:center;line-height:20px;font-size:11px;margin-right:8px;">${num}</span>${title}
      </td>
    </tr>`;
  const twoColRow = (label, pVal, sVal) => `
    <tr>
      <td style="padding:6px 10px;font-size:13px;color:#222;border-bottom:1px solid #e5e7eb;">${label}</td>
      <td style="padding:6px 10px;font-size:13px;color:#1a2744;font-weight:600;border-bottom:1px solid #e5e7eb;text-align:right;">${pVal}</td>
      <td style="padding:6px 10px;font-size:13px;color:#1a2744;font-weight:600;border-bottom:1px solid #e5e7eb;text-align:right;">${sVal}</td>
    </tr>`;
  const twoColHdr = () => `
    <tr style="background:#f5edda;">
      <td style="padding:6px 10px;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;"></td>
      <td style="padding:6px 10px;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;text-align:right;">Principal</td>
      <td style="padding:6px 10px;font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;text-align:right;">Spouse</td>
    </tr>`;

  return `
  <div style="font-family:-apple-system,Segoe UI,sans-serif;max-width:640px;margin:0 auto;background:#f7f8fa;padding:20px;">

    <div style="background:#1a2744;border-radius:10px 10px 0 0;padding:18px 20px;">
      <div style="color:#c9a84c;font-size:18px;font-weight:700;letter-spacing:.02em;">Retirement Right</div>
      <div style="color:#fff;opacity:.75;font-size:12px;margin-top:2px;">Pre-Appointment Information — Confidential</div>
    </div>

    <div style="background:#f5edda;border:1px solid #c9a84c;border-top:none;padding:14px 20px;font-size:12px;color:#5a4a1a;">
      Submitted ${new Date().toLocaleString()}
