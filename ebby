        <p style="font-size:.82rem;color:var(--muted);margin-bottom:14px">Check all that are currently in place:</p>
        <ul class="check-list">
          <li><label><input type="checkbox" name="estate" value="Trust or Will"> Trust or Will</label></li>
          <li><label><input type="checkbox" name="estate" value="Powers of Attorney"> Powers of Attorney</label></li>
          <li><label><input type="checkbox" name="estate" value="Living Will / Directive"> Living Will / Directive</label></li>
          <li><label><input type="checkbox" name="estate" value="Beneficiaries Updated"> Beneficiaries Updated</label></li>
          <li><label><input type="checkbox" name="estate" value="Retirement Planning Done"> Retirement Planning Done Previously</label></li>
