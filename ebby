          <tr>
            <td>IRA Balance #1</td>
            <td><div class="dollar-wrap"><input type="text" id="ira_p1" class="dollar-input" placeholder="0"></div></td>
            <td><div class="dollar-wrap"><input type="text" id="ira_s1" class="dollar-input" placeholder="0"></div></td>
