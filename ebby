              <div style="font-size:.78rem;color:var(--muted);margin-top:2px">If not yet collecting, enter your FRA benefit. If already collecting, enter your current monthly amount.</div>
            </td>
            <td><div class="dollar-wrap"><input type="text" id="ss_p" class="dollar-input" placeholder="0"></div></td>
            <td><div class="dollar-wrap"><input type="text" id="ss_s" class="dollar-input" placeholder="0"></div></td>
