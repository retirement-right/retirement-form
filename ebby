      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px">
        <div class="field"><label class="field-label">Email</label><input type="email" id="p_email" placeholder="your@email.com"></div>
        <div class="field"><label class="field-label">Phone</label><input type="tel" id="p_phone" placeholder="(000) 000-0000"></div>
